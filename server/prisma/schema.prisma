generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/generated-prisma-client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum SubscriptionPlan {
  FREE
  BASIC
  PRO
}

enum UserRole {
  SUPER_ADMIN
  AGENCY_ADMIN
  BROKER
}

enum LeadSource {
  WALK_IN
  PHONE
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  SITE_VISIT
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum LeadPriority {
  HOT
  WARM
  COLD
}

enum PropertyType {
  APARTMENT
  VILLA
  PLOT
  COMMERCIAL
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RESERVED
}

enum InterestLevel {
  HIGH
  MEDIUM
  LOW
}

enum CommunicationType {
  CALL
  MEETING
  EMAIL
  SMS
  NOTE
}

// ─── Models ──────────────────────────────────────────────

model Agency {
  id               String           @id @default(uuid())
  name             String
  address          String?
  phone            String?
  email            String?
  logoUrl          String?
  subscriptionPlan SubscriptionPlan @default(FREE)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  users      User[]
  leads      Lead[]
  properties Property[]
}

model User {
  id           String    @id @default(uuid())
  agencyId     String?
  role         UserRole  @default(BROKER)
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  agency Agency? @relation(fields: [agencyId], references: [id])

  assignedLeads      Lead[]          @relation("AssignedTo")
  createdLeads       Lead[]          @relation("CreatedBy")
  communications     Communication[] @relation("CreatedCommunications")
  assignedFollowUps  Communication[] @relation("AssignedFollowUps")
  notifications      Notification[]
  leadActivities     LeadActivity[]

  @@index([agencyId])
}

model Lead {
  id                     String       @id @default(uuid())
  agencyId               String
  assignedToId           String?
  createdById            String
  firstName              String
  lastName               String
  email                  String?
  phone                  String?
  source                 LeadSource   @default(OTHER)
  status                 LeadStatus   @default(NEW)
  priority               LeadPriority @default(WARM)
  budgetMin              Float?
  budgetMax              Float?
  preferredLocation      String?
  propertyTypePreference String?
  notes                  String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  agency     Agency @relation(fields: [agencyId], references: [id])
  assignedTo User?  @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User   @relation("CreatedBy", fields: [createdById], references: [id])

  leadProperties LeadProperty[]
  communications Communication[]
  activities     LeadActivity[]

  @@index([agencyId])
  @@index([assignedToId])
  @@index([status])
  @@index([createdAt])
}

model Property {
  id          String         @id @default(uuid())
  agencyId    String
  name        String
  type        PropertyType
  address     String?
  city        String?
  state       String?
  zip         String?
  latitude    Float?
  longitude   Float?
  price       Float?
  areaSqft    Float?
  bedrooms    Int?
  bathrooms   Int?
  status      PropertyStatus @default(AVAILABLE)
  description String?
  images      Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id])

  leadProperties LeadProperty[]

  @@index([agencyId])
  @@index([status])
}

model LeadProperty {
  id            String        @id @default(uuid())
  leadId        String
  propertyId    String
  interestLevel InterestLevel @default(MEDIUM)
  notes         String?
  createdAt     DateTime      @default(now())

  lead     Lead     @relation(fields: [leadId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([leadId, propertyId])
  @@index([leadId])
  @@index([propertyId])
}

model Communication {
  id             String            @id @default(uuid())
  leadId         String
  userId         String
  assignedToId   String?
  type           CommunicationType
  subject        String?
  body           String?
  outcome        String?
  isFollowUp     Boolean           @default(false)
  scheduledAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())

  lead       Lead  @relation(fields: [leadId], references: [id])
  user       User  @relation("CreatedCommunications", fields: [userId], references: [id])
  assignedTo User? @relation("AssignedFollowUps", fields: [assignedToId], references: [id])

  @@index([leadId])
  @@index([userId])
  @@index([assignedToId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String?
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  userId    String
  action    String
  oldValue  String?
  newValue  String?
  metadata  Json?
  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
}

// ─── Running Coach Enums ─────────────────────────────────

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ELITE
}

enum GoalType {
  FIVE_K
  TEN_K
  HALF_MARATHON
  FULL_MARATHON
  CUSTOM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum ActivityType {
  EASY_RUN
  TEMPO
  INTERVAL
  LONG_RUN
  REST
  CROSS_TRAIN
  RACE
}

enum PlanItemStatus {
  PENDING
  COMPLETED
  SKIPPED
  MODIFIED
}

enum CoachInteractionType {
  GREETING
  CHECK_IN
  CONGRATULATION
  PLAN_ADJUSTMENT
  STREAK_WARNING
  BADGE_AWARD
}

// ─── Running Coach Models ────────────────────────────────

model RunnerProfile {
  id                   String          @id @default(uuid())
  email                String          @unique
  passwordHash         String
  name                 String
  age                  Int?
  weightKg             Float?
  experienceLevel      ExperienceLevel @default(BEGINNER)
  currentWeeklyKm      Float?
  currentPaceMinPerKm  Float?          // e.g., 6.5 = 6:30/km
  fitnessLevel         Int?            @default(5) // 1-10 scale
  xpPoints             Int             @default(0)
  level                Int             @default(1)
  currentStreak        Int             @default(0)
  longestStreak        Int             @default(0)
  lastActiveDate       DateTime?
  onboardingCompleted  Boolean         @default(false)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  goals           RunningGoal[]
  trainingPlans   TrainingPlan[]
  activityLogs    ActivityLog[]
  badges          RunnerBadge[]
  coachInteractions CoachInteraction[]

  @@map("runner_profiles")
}

model RunningGoal {
  id             String     @id @default(uuid())
  runnerId       String
  goalType       GoalType
  targetDistanceKm Float?
  targetTimeMinutes Float?
  targetDate     DateTime?
  status         GoalStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  runner        RunnerProfile @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  trainingPlans TrainingPlan[]

  @@index([runnerId])
  @@index([status])
  @@map("running_goals")
}

model TrainingPlan {
  id              String         @id @default(uuid())
  runnerId        String
  goalId          String
  weekNumber      Int
  dayOfWeek       Int            // 1=Monday, 7=Sunday
  activityType    ActivityType
  targetDistanceKm Float?
  targetPaceMinPerKm Float?
  targetDurationMin Float?
  description     String?
  status          PlanItemStatus @default(PENDING)
  scheduledDate   DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  runner       RunnerProfile @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  goal         RunningGoal   @relation(fields: [goalId], references: [id], onDelete: Cascade)
  activityLogs ActivityLog[]

  @@index([runnerId])
  @@index([goalId])
  @@index([scheduledDate])
  @@map("training_plans")
}

model ActivityLog {
  id              String    @id @default(uuid())
  runnerId        String
  planItemId      String?   // null if unplanned/ad-hoc activity
  date            DateTime
  distanceKm      Float
  durationMinutes Float
  avgPaceMinPerKm Float?
  effortLevel     Int?      // 1-10
  notes           String?
  wasPlanned      Boolean   @default(false)
  xpEarned        Int       @default(0)
  createdAt       DateTime  @default(now())

  runner   RunnerProfile  @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  planItem TrainingPlan?  @relation(fields: [planItemId], references: [id], onDelete: SetNull)

  @@index([runnerId])
  @@index([date])
  @@map("activity_logs")
}

model Badge {
  id          String @id @default(uuid())
  name        String @unique
  description String
  iconName    String
  xpReward    Int    @default(50)
  criteria    String // JSON string describing unlock criteria

  runners RunnerBadge[]

  @@map("badges")
}

model RunnerBadge {
  id       String   @id @default(uuid())
  runnerId String
  badgeId  String
  earnedAt DateTime @default(now())

  runner RunnerProfile @relation(fields: [runnerId], references: [id], onDelete: Cascade)
  badge  Badge         @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([runnerId, badgeId])
  @@index([runnerId])
  @@map("runner_badges")
}

model CoachInteraction {
  id           String                @id @default(uuid())
  runnerId     String
  type         CoachInteractionType
  message      String
  userResponse String?
  metadata     Json?
  createdAt    DateTime              @default(now())

  runner RunnerProfile @relation(fields: [runnerId], references: [id], onDelete: Cascade)

  @@index([runnerId])
  @@index([createdAt])
  @@map("coach_interactions")
}
